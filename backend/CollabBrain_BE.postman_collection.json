{
  "info": {
    "_postman_id": "3d4f2a2d-5f4c-4e0d-9b5e-collabbrain-be",
    "name": "CollabBrain BE",
    "description": "Postman collection test tất cả routes hiện có của BE.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "email",
      "value": "test@example.com",
      "type": "string"
    },
    {
      "key": "password",
      "value": "123456",
      "type": "string"
    },
    {
      "key": "newPassword",
      "value": "1234567",
      "type": "string"
    },
    {
      "key": "name",
      "value": "Test User",
      "type": "string"
    },
    {
      "key": "otp",
      "value": "123456",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "Register - Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"name\": \"{{name}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 400', function () {",
                  "  pm.expect([200, 400]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\",\n  \"password\": \"{{password}}\",\n  \"name\": \"{{name}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/register/verify-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "register",
                "verify-otp"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Response is JSON', function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (pm.response.code === 200 && json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Response is JSON', function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (pm.response.code === 200 && json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password - Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/forgot-password/forgot",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
