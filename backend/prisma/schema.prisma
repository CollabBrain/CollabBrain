generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model Account {
  id           String      @id @default(uuid())
  passwordHash String      @map("password_hash")
  role         AccountRole @default(STAFF)
  isActive     Boolean     @default(true) @map("is_active")
  isDeleted    Boolean     @default(false) @map("is_deleted")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  username     String      @unique

  @@map("accounts")
}

model User {
  id                  String            @id @default(uuid())
  name                String
  avatarUrl           String?           @map("avatar_url")
  bio                 String?
  isActive            Boolean           @default(true) @map("is_active")
  createdAt           DateTime          @default(now()) @map("created_at")
  isDeleted           Boolean           @default(false) @map("is_deleted")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  email               String            @unique
  passwordHash        String            @map("password_hash")
  coverUrl            String?           @map("cover_url")
  documents           Document[]
  receivedFriendships Friendship[]      @relation("ReceivedFriendships")
  sentFriendships     Friendship[]      @relation("SentFriendships")
  sentInvitations     GroupInvitation[] @relation("InvitationSender")
  groupInvitations    GroupInvitation[] @relation("InvitationUser")
  groups              GroupMember[]
  messageMentions     MessageMention[]
  pinnedMessages      Message[]         @relation("PinnedMessages")
  receivedMessages    Message[]         @relation("ReceivedMessages")
  sentMessages        Message[]         @relation("SentMessages")
  reportsSent         Report[]          @relation("Reporter")
  reportsReceived     Report[]          @relation("ReportedUser")

  @@map("users")
}

model Group {
  id          String            @id @default(uuid())
  name        String
  description String?
  avatarUrl   String?           @map("avatar_url")
  isActive    Boolean           @default(true) @map("is_active")
  isDeleted   Boolean           @default(false) @map("is_deleted")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  visibility  GroupVisibility   @default(PUBLIC)
  coverUrl    String?           @map("cover_url")
  documents   Document[]
  invitations GroupInvitation[]
  members     GroupMember[]
  messages    Message[]
  reports     Report[]

  @@map("groups")
}

model GroupMember {
  groupId   String    @map("group_id")
  userId    String    @map("user_id")
  role      GroupRole @default(MEMBER)
  joinedAt  DateTime  @default(now()) @map("joined_at")
  invitedBy String?   @map("invited_by")
  group     Group     @relation(fields: [groupId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@id([groupId, userId])
  @@map("group_members")
}

model Document {
  id         String          @id @default(uuid())
  name       String
  type       DocumentType
  url        String
  size       Int?
  isEmbedded Boolean         @default(false) @map("is_embedded")
  isDeleted  Boolean         @default(false) @map("is_deleted")
  createdAt  DateTime        @default(now()) @map("created_at")
  groupId    String?         @map("group_id")
  uploadedBy String          @map("uploaded_by")
  mimeType   String?         @map("mime_type")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  chunks     DocumentChunk[]
  group      Group?          @relation(fields: [groupId], references: [id])
  uploader   User            @relation(fields: [uploadedBy], references: [id])

  @@index([groupId, createdAt])
  @@index([uploadedBy, createdAt])
  @@map("documents")
}

model DocumentChunk {
  id          String   @id @default(uuid())
  content     String
  chunkIndex  Int      @map("chunk_index")

  contentHash String?  @unique

  embedding   Unsupported("vector(384)")?

  isEmbedded  Boolean  @default(false)

  documentId  String   @map("document_id")
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([documentId, chunkIndex])
  @@map("document_chunks")
}

model OtpVerification {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("otp_verifications")
}

model Friendship {
  senderId   String           @map("sender_id")
  receiverId String           @map("receiver_id")
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  receiver   User             @relation("ReceivedFriendships", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User             @relation("SentFriendships", fields: [senderId], references: [id], onDelete: Cascade)

  @@id([senderId, receiverId])
  @@map("friendships")
}

model GroupInvitation {
  id        String           @id @default(uuid())
  type      InvitationType
  status    InvitationStatus @default(PENDING)
  groupId   String           @map("group_id")
  userId    String           @map("user_id")
  invitedBy String?          @map("invited_by")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  group     Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User?            @relation("InvitationSender", fields: [invitedBy], references: [id])
  user      User             @relation("InvitationUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_invitations")
}

model Message {
  id                String           @id @default(uuid())
  content           String
  type              MessageType      @default(TEXT)
  senderId          String           @map("sender_id")
  receiverId        String?          @map("receiver_id")
  groupId           String?          @map("group_id")
  isRead            Boolean          @default(false) @map("is_read")
  createdAt         DateTime         @default(now()) @map("created_at")
  deletedBySender   Boolean          @default(false) @map("deleted_by_sender")
  deletedByReceiver Boolean          @default(false) @map("deleted_by_receiver")
  isPinned          Boolean          @default(false) @map("is_pinned")
  isRecalled        Boolean          @default(false) @map("is_recalled")
  pinnedAt          DateTime?        @map("pinned_at")
  pinnedBy          String?          @map("pinned_by")
  replyToId         String?          @map("reply_to_id")
  mentions          MessageMention[]
  group             Group?           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  pinner            User?            @relation("PinnedMessages", fields: [pinnedBy], references: [id])
  receiver          User?            @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  replyTo           Message?         @relation("MessageReplies", fields: [replyToId], references: [id])
  replies           Message[]        @relation("MessageReplies")
  sender            User             @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([receiverId, createdAt])
  @@index([groupId, createdAt])
  @@index([groupId, isPinned])
  @@map("messages")
}

model MessageMention {
  id        String  @id @default(uuid())
  messageId String  @map("message_id")
  userId    String  @map("user_id")
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("message_mentions")
}

model Report {
  id            String       @id @default(uuid())
  reporterId    String       @map("reporter_id")
  targetUserId  String?      @map("target_user_id")
  targetGroupId String?      @map("target_group_id")
  reason        String
  status        ReportStatus @default(PENDING)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  reporter      User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetGroup   Group?       @relation(fields: [targetGroupId], references: [id], onDelete: Cascade)
  targetUser    User?        @relation("ReportedUser", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@map("reports")
}

enum AccountRole {
  ADMIN
  MANAGER
  STAFF
}

enum GroupRole {
  OWNER
  MEMBER
  VIEWER
}

enum DocumentType {
  PDF
  DOCX
  LINK
  IMAGE
  PPTX
  XLSX
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum GroupVisibility {
  PUBLIC
  PRIVATE
  INVITE
}

enum InvitationType {
  REQUEST
  INVITE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ReportStatus {
  PENDING
  RESOLVED
}
